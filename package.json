{
  "name": "onixggr",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev:api": "go run ./apps/api",
    "dev:worker": "go run ./apps/worker",
    "dev:scheduler": "go run ./apps/scheduler",
    "test:go": "go test ./...",
    "dev:web": "npm --workspace @onixggr/web run dev",
    "build:web": "npm --workspace @onixggr/web run build",
    "check:web": "npm --workspace @onixggr/web run check",
    "lint:web": "npm --workspace @onixggr/web run lint",
    "format:web": "npm --workspace @onixggr/web run format"
  }
}
