# Compose / routing
# Production deploy now uses a single entrypoint:
#   ./deploy/production/deploy.sh
# If both ports below bind to 127.0.0.1, deploy.sh automatically runs
# in Cloudflare Tunnel mode and swaps the internal Caddyfile override.
COMPOSE_PROJECT_NAME=onixggr-prod
PRODUCTION_DOMAIN=app.example.com
APP_URL=https://app.example.com
TLS_EMAIL=ops@example.com
PRODUCTION_HTTP_PORT=80
PRODUCTION_HTTPS_PORT=443
# Cloudflare Tunnel mode:
# PRODUCTION_HTTP_PORT=127.0.0.1:18080
# PRODUCTION_HTTPS_PORT=127.0.0.1:18443
PRODUCTION_REQUIRE_BACKUP_BEFORE_MIGRATE=1
PRODUCTION_BACKUP_RETENTION_DAYS=14

# App
APP_NAME=onixggr
APP_ENV=production
APP_TIMEZONE=Asia/Jakarta
APP_LOG_LEVEL=info

# Database
POSTGRES_DB=onixggr
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
DATABASE_MAX_OPEN_CONNS=30
DATABASE_MAX_IDLE_CONNS=30
DATABASE_CONN_MAX_LIFETIME=15m

# Redis
REDIS_PASSWORD=change-me-redis-password
REDIS_DB=0

# Auth
JWT_ACCESS_SECRET=change-me-jwt-secret
JWT_ACCESS_TTL=1h
SESSION_TTL=168h
SESSION_CLEANUP_INTERVAL=1h
PASSWORD_BCRYPT_COST=12
AUTH_ENCRYPTION_KEY=change-me-auth-encryption-key
TOTP_ENROLLMENT_TTL=10m
LOGIN_ATTEMPT_WINDOW=15m
LOGIN_MAX_ATTEMPTS_PER_IP=20
LOGIN_MAX_ATTEMPTS_PER_IDENTIFIER=5

# Business values
MIN_TRANSACTION_AMOUNT=5000
STORE_LOW_BALANCE_THRESHOLD=100000
MEMBER_PAYMENT_PLATFORM_FEE_PERCENT=3
STORE_WITHDRAW_PLATFORM_FEE_PERCENT=12

# Callback delivery
CALLBACK_SIGNING_SECRET=change-me-callback-signing-secret
CALLBACK_DELIVERY_TIMEOUT=10s
CALLBACK_ATTEMPT_RETENTION_PERIOD=720h
CALLBACK_ATTEMPT_PRUNE_INTERVAL=24h

# QRIS Provider
QRIS_BASE_URL=https://qris.provider.example
QRIS_CLIENT=change-me-qris-client
QRIS_CLIENT_KEY=change-me-qris-client-key
QRIS_GLOBAL_UUID=change-me-qris-global-uuid
QRIS_DEFAULT_EXPIRE_SECONDS=300
QRIS_BANK_INQUIRY_AMOUNT=10000
QRIS_BANK_INQUIRY_TYPE=2
QRIS_WEBHOOK_SHARED_SECRET=change-me-qris-webhook-secret

# NexusGGR
NEXUSGGR_BASE_URL=https://nexus.provider.example
NEXUSGGR_AGENT_CODE=change-me-nexusggr-agent-code
NEXUSGGR_AGENT_TOKEN=change-me-nexusggr-agent-token
NEXUSGGR_TIMEOUT=10s
PROVIDER_CATALOG_SYNC_INTERVAL=30m

# Workers / scheduler
LOW_BALANCE_SWEEP_INTERVAL=15m
LOW_BALANCE_ALERT_COOLDOWN=6h
GAME_RECONCILE_INTERVAL=30s
GAME_RECONCILE_BATCH_SIZE=50
QRIS_RECONCILE_INTERVAL=30s
QRIS_RECONCILE_BATCH_SIZE=50
WITHDRAW_RECONCILE_INTERVAL=30s
WITHDRAW_RECONCILE_BATCH_SIZE=50
CALLBACK_RETRY_INTERVAL=15s
CALLBACK_RETRY_BATCH_SIZE=50
AUDIT_RETENTION_PERIOD=2160h
AUDIT_PRUNE_INTERVAL=24h
CHAT_RETENTION_PERIOD=168h
CHAT_PRUNE_INTERVAL=1h

# Realtime / observability
WS_HEARTBEAT_SECONDS=30
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# Smoke defaults
SMOKE_OWNER_LOGIN=
SMOKE_OWNER_PASSWORD=
SMOKE_STORE_ID=
SMOKE_STORE_TOKEN=
SMOKE_STORE_MEMBER=
